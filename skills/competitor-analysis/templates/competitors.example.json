{
  "_schema_hint": {
    "type": "'product' = 产品型竞品（整体对标，截所有模块） | 'feature' = 功能型竞品（跨行业某功能最佳实践，只截 targetModules 列出的模块）",
    "targetModules": "仅 feature 型必填；数组，每项必须是 product-profile.modules 里的 id",
    "loginRequired": "true 则 step3 会自动弹浏览器让用户登录（每个竞品只需登一次，state 保存到 .auth/）",
    "moduleUrls": "key = module id, value = 该竞品对应该模块的真实功能页 URL。对于需要登录才有真 UI 的产品，这里可以先填营销页，登录后 step3 会用同一 URL 重截",
    "appUrl": "（可选）登录后真实工作台的入口，例如 https://app.xxx.com/ — 比 moduleUrls 的营销页更能看到真 UI",
    "demoVideoUrl": "（可选）官方 demo 视频 URL（MP4 直链 / YouTube / Vimeo）。当 step3 登录后仍然截不到真 UI 时，会自动抽帧 fallback",
    "_v03_1_changes": "所有产品型竞品默认 loginRequired: true。因为几乎所有 SaaS 未登录看到的都是营销页，只有登录后才能截到真实 UI 作为分析素材"
  },
